{
  "version": 2,
  "builds": [
    { "src": "api/schedule.js",     "use": "@vercel/node" },
    { "src": "api/signup-data.js",  "use": "@vercel/node" },
    { "src": "api/signup.js",       "use": "@vercel/node" },
    { "src": "*.html",              "use": "@vercel/static" },
    { "src": "favicon.svg",         "use": "@vercel/static" },
    { "src": "api/generate-invoices.js", "use": "@vercel/node" },
    { "src": "api/send-invoices.js", "use": "@vercel/node" },
    { "src": "api/admin-invoices.js", "use": "@vercel/node" },
    { "src": "api/preview-invoice.js", "use": "@vercel/node" },
    { "src": "api/generate-pdf-batch.js", "use": "@vercel/node" },
    { "src": "api/payment-reminder.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/schedule",     "dest": "/api/schedule.js"    },
    { "src": "/api/signup-data",  "dest": "/api/signup-data.js" },
    { "src": "/api/signup",       "dest": "/api/signup.js"      },
    { "src": "/signup",           "dest": "/signup.html"        },
    { "src": "/thankyou",         "dest": "/thankyou.html"      },
    { "src": "/terms",            "dest": "/terms.html"         },
    { "src": "/admin",            "dest": "/admin.html"         },
    { "src": "/",                 "dest": "/index.html"         },
    { "src": "/api/generate-invoices", "dest": "/api/generate-invoices.js" },
    { "src": "/api/send-invoices", "dest": "/api/send-invoices.js" },
    { "src": "/api/admin-invoices", "dest": "/api/admin-invoices.js" },
    { "src": "/api/preview-invoice", "dest": "/api/preview-invoice.js" },
    { "src": "/api/generate-pdf-batch", "dest": "/api/generate-pdf-batch.js" },
    { "src": "/api/payment-reminder", "dest": "/api/payment-reminder.js" },
    { "src": "/(.*)",             "dest": "/$1"                 }
  ],
  "crons": [
    { "path": "/api/payment-reminder", "schedule": "0 0 14 * *" },
    { "path": "/api/generate-invoices", "schedule": "0 23 14 * *" },
    { "path": "/api/send-invoices", "schedule": "0 2 15 * *" }
  ]
}
