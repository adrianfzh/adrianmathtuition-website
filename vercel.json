{
  "version": 2,
  "builds": [
    {
      "src": "api/schedule.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/schedule",
      "dest": "/api/schedule.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
